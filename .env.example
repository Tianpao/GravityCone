# Microsoft OAuth2 credentials for Minecraft login
# These are used for LOCAL DEVELOPMENT only when ldflags are not set.
# For production builds, pass via: task build MS_CLIENT_ID=xxx MS_CLIENT_SECRET=yyy
# Obtain from https://portal.azure.com → App registrations
MS_CLIENT_ID=
MS_CLIENT_SECRET=

# Naidseal OAuth2 credentials for Natayark login
# These are used for LOCAL DEVELOPMENT only when ldflags are not set.
# For production builds, pass via: task build NAIDS_CLIENT_ID=xxx NAIDS_CLIENT_SECRET=yyy
# Obtain from https://account.naids.com/feat/appOAuth

NAIDS_CLIENT_ID=
NAIDS_CLIENT_SECRET=